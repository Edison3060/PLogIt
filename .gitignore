# ============================================================
# PLogIt - .gitignore
# ============================================================

# ---- Secrets / environment ----
.env
.env.*
!.env.example

# ---- Java / Maven (backend) ----
backend/target/
*.class
hs_err_pid*
replay_pid*

# ---- Node / Vite (frontend) ----
frontend/node_modules/
frontend/dist/
frontend/.vite/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ---- IntelliJ / IDE ----
.idea/
*.iml
*.iws
out/
.vscode/
*.swp

# ---- OS junk ----
.DS_Store
Thumbs.db

# ---- Local data / runtime ----
pgdata/
attachments/
*.local
*.log
