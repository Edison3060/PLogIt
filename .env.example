# ============================================================
# PLogIt - environment variables (COMMITTED TEMPLATE)
# Copy to .env and fill in real values. NEVER commit .env.
#   cp .env.example .env
# ============================================================

# ---- PostgreSQL (the `db` container) ----
POSTGRES_DB=plogit
POSTGRES_USER=plogit
POSTGRES_PASSWORD=change-me-strong-db-password

# ---- Backend datasource ----
# Use this (localhost) when running backend from IntelliJ against dockerized
# Postgres. Inside docker-compose the backend service overrides the host to
# `db:5432` automatically - see docker-compose.yml.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/plogit
SPRING_DATASOURCE_USERNAME=plogit
SPRING_DATASOURCE_PASSWORD=change-me-strong-db-password

# ---- Spring profile (dev | prod) ----
SPRING_PROFILES_ACTIVE=dev

# ---- Auth secret (Spring Security sessions) ----
# Long random string. Generate one with:  openssl rand -base64 48
APP_SESSION_SECRET=change-me-long-random-secret

# ---- CORS (dev only - the Vite dev server origin) ----
APP_CORS_ORIGINS=http://localhost:5173

# ---- File storage (attachments) ----
# Absolute path to the attachments directory. Inside docker-compose the
# backend service mounts a named volume here.
APP_STORAGE_DIR=/data/attachments

# ---- Seed demo user (created on first run, dev profile only) ----
SEED_USER_EMAIL=leader@plogit.local
SEED_USER_PASSWORD=change-me-leader
SEED_USER_NAME=Demo Leader

# ============================================================
# DEPLOY ONLY (Slice 11 - server + domain + TLS). Leave blank until then.
# ============================================================
# Your domain, e.g. plogit.example.com
APP_DOMAIN=
# Email Let's Encrypt uses for cert notices (Caddy)
ACME_EMAIL=
